# Secrets — never commit
.secrets
.secrets.*
.env
.env.*
*.pem
*.key

# Node / future SPA build
node_modules/
dist/
build/
.vite/

# release/ IS tracked. The DHA workstation cannot run npm/node, so the
# built single-file artifact (release/index.html) is the deliverable
# that gets committed and pulled there. Rebuild and re-stage on every
# change to src/.
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS / editor noise
.DS_Store
Thumbs.db
desktop.ini
